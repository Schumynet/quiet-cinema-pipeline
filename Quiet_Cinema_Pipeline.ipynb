    "# @title Step 6: Aggiungi Audio e Crea Video Finale\n",
    "\n",
    "import os\n",
    "import subprocess\n",
    "\n",
    "def combine_audio_video(video_file, audio_file, output_file):\n",
    "    \"\"\"Combina video e audio\"\"\"\n",
    "    \n",
    "    # Ottieni durata video\n",
    "    result = subprocess.run(\n",
    "        [\"ffprobe\", \"-v\", \"error\", \"-show_entries\", \"format=duration\",\n",
    "         \"-of\", \"default=noprint_wrappers=1:nokey=1\", video_file],\n",
    "        capture_output=True, text=True\n",
    "    )\n",
    "    video_duration = float(result.stdout.strip())\n",
    "    \n",
    "    # Estendi audio se necessario\n",
    "    cmd = f\"\"\"\n",
    "    ffmpeg -y \n",
    "    -i \"{video_file}\" \n",
    "    -streamlooploop 1 -i \"{audio_file}\"\n",
    "    -t {video_duration}\n",
    "    -c:v copy -c:a aac -b:a 192k\n",
    "    -shortest\n",
    "    \"{output_file}\"\n",
    "    \"\"\"\n",
    "    \n",
    "    subprocess.run(cmd, shell=True, check=True)\n",
    "    print(f\"✅ Video finale creato: {output_file}\")\n",
    "    return output_file\n",
    "\n",
    "def add_ken_burns_effect(input_image, output_video, duration=5):\n",
    "    \"\"\"Aggiunge effetto Ken Burns a un'immagine\"\"\"\n",
    "    \n",
    "    import random\n",
    "    \n",
    "    # Zoom casuale\n",
    "    zoom_start = 1.0\n",
    "    zoom_end = 1.1 + random.random() * 0.1\n",
    "    \n",
    "    # Movimento casuale\n",
    "    x_start = random.uniform(-0.05, 0.05)\n",
    "    y_start = random.uniform(-0.05, 0.05)\n",
    "    x_end = random.uniform(-0.05, 0.05)\n",
    "    y_end = random.uniform(-0.05, 0.05)\n",
    "    \n",
    "    scale_filter = f\"zoompan=z='min(zoom+0.005,{zoom_end})':d={int(duration*25)}:s=1920x1080\"\n",
    "    pan_filter = f\"pan=2:c=c0:c1=c0\"\n",
    "    \n",
    "    cmd = f\"\"\"\n",
    "    ffmpeg -y -loop 1 -i \"{input_image}\"\n",
    "    -vf \"scale=1920:1080:force_original_aspect_ratio=increase,crop=1920:1080,{scale_filter}\"\n",
    "    -t {duration} -r 25 -c:v libx264 -preset medium -crf 20 -pix_fmt yuv420p\n",
    "    \"{output_video}\"\n",
    "    \"\"\"\n",
    "    \n",
    "    subprocess.run(cmd, shell=True, check=True)\n",
    "    print(f\"✅ Ken Burns video: {output_video}\")\n",
    "    return output_video\n",
    "\n",
    "# Genera video Ken Burns per ogni immagine\n",
    "ken_burns_videos = []\n",
    "images_dir = f\"{WORK_DIR}/images\"\n",
    "images = sorted([f for f in os.listdir(images_dir) if f.endswith(('.png', '.jpg'))])\n",
    "\n",
    "for i, img in enumerate(images):\n",
    "    kb_video = f\"{WORK_DIR}/video/kenburns_{i:02d}.mp4\"\n",
    "    add_ken_burns_effect(f\"{images_dir}/{img}\", kb_video, duration=5)\n",
    "    ken_burns_videos.append(kb_video)\n",
    "\n",
    "print(f\"\\n✅ Generate {len(ken_burns_videos)} Ken Burns videos!\")"
   ]
