    "# @title Step 8: Genera Thumbnail\n",
    "\n",
    "from PIL import Image, ImageDraw, ImageFont\n",
    "import os\n",
    "\n",
    "def create_thumbnail(title, output_path):\n",
    "    \"\"\"Crea thumbnail per YouTube\"\"\"\n",
    "    \n",
    "    # Usa la prima immagine come sfondo\n",
    "    first_image = f\"{WORK_DIR}/images/scene_00.png\"\n",
    "    \n",
    "    if os.path.exists(first_image):\n",
    "        # Apri e ridimensiona\n",
    "        bg = Image.open(first_image).convert('RGBA')\n",
    "        bg = bg.resize((1280, 720), Image.LANCZOS)\n",
    "    else:\n",
    "        # Crea sfondo nero\n",
    "        bg = Image.new('RGBA', (1280, 720), (20, 20, 30, 255))\n",
    "    \n",
    "    # Aggiungi overlay scuro\n",
    "    overlay = Image.new('RGBA', bg.size, (0, 0, 0, 0))\n",
    "    draw = ImageDraw.Draw(overlay)\n",
    "    draw.rectangle([(0, 500), (1280, 720)], fill=(0, 0, 0, 180))\n",
    "    bg = Image.alpha_composite(bg, overlay)\n",
    "    bg = bg.convert('RGB')\n",
    "    \n",
    "    # Aggiungi testo\n",
    "    draw = ImageDraw.Draw(bg)\n",
    "    \n",
    "    # Titolo principale (segue stile oltsevart)\n",
    "    try:\n",
    "        font_large = ImageFont.truetype(\"/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf\", 48)\n",
    "        font_small = ImageFont.truetype(\"/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf\", 28)\n",
    "    except:\n",
    "        font_large = ImageFont.load_default()\n",
    "        font_small = ImageFont.load_default()\n",
    "    \n",
    "    # Dividi titolo se troppo lungo\n",
    "    words = title.split(' | ')\n",
    "    if len(words) > 1:\n",
    "        draw.text((640, 560), words[0], font=font_large, fill='white', anchor='mm')\n",
    "        draw.text((640, 620), words[1], font=font_small, fill='#CCCCCC', anchor='mm')\n",
    "    else:\n",
    "        draw.text((640, 580), title[:60], font=font_large, fill='white', anchor='mm')\n",
    "    \n",
    "    # Aggiungi watermark\n",
    "    draw.text((1230, 700), \"Quiet Cinema\", font=font_small, fill='#888888', anchor='rm')\n",
    "    \n",
    "    # Salva\n",
    "    bg.save(output_path, 'PNG', quality=95)\n",
    "    print(f\"✅ Thumbnail creata: {output_path}\")\n",
    "    return output_path\n",
    "\n",
    "# Genera thumbnail\n",
    "thumbnail = create_thumbnail(\n",
    "    titolo_video,\n",
    "    f\"{WORK_DIR}/final/thumbnail.png\"\n",
    ")\n",
    "\n",
    "print(f\"\\n🎨 Thumbnail pronta per upload!\")"
   ]
