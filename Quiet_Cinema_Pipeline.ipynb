    "# @title Step 7: Merge Finale con Transizioni\n",
    "\n",
    "import os\n",
    "import subprocess\n",
    "\n",
    "def create_final_video(video_clips, audio_file, output_file):\n",
    "    \"\"\"Crea video finale con transizioni\"\"\"\n",
    "    \n",
    "    # Crea lista per concat\n",
    "    concat_file = f\"{WORK_DIR}/final/concat.txt\"\n",
    "    with open(concat_file, 'w') as f:\n",
    "        for clip in video_clips:\n",
    "            if os.path.exists(clip):\n",
    "                f.write(f\"file '{clip}'\\n\")\n",
    "    \n",
    "    # Merge video\n",
    "    merged_video = f\"{WORK_DIR}/final/merged_video.mp4\"\n",
    "    subprocess.run([\n",
    "        \"ffmpeg\", \"-y\", \"-f\", \"concat\", \"-safe\", \"0\",\n",
    "        \"-i\", concat_file,\n",
    "        \"-c\", \"copy\", merged_video\n",
    "    ], check=True)\n",
    "    \n",
    "    # Ottieni durata\n",
    "    result = subprocess.run(\n",
    "        [\"ffprobe\", \"-v\", \"error\", \"-show_entries\", \"format=duration\",\n",
    "         \"-of\", \"default=noprint_wrappers=1:nokey=1\", merged_video],\n",
    "        capture_output=True, text=True\n",
    "    )\n",
    "    video_duration = float(result.stdout.strip()) if result.stdout.strip() else 60\n",
    "    \n",
    "    # Aggiungi audio\n",
    "    cmd = f\"\"\"\n",
    "    ffmpeg -y -i \"{merged_video}\" -i \"{audio_file}\"\n",
    f\"    -t {video_duration} -c:v copy -c:a aac -b:a 192k -shortest\n",
    "    \"{output_file}\"\n",
    "    \"\"\"\n",
    "    \n",
    "    subprocess.run(cmd, shell=True, check=True)\n",
    "    print(f\"\\n🎬 VIDEO FINALE CREATO: {output_file}\")\n",
    "    \n",
    "    # Verifica\n",
    "    file_size = os.path.getsize(output_file) / (1024*1024)\n",
    "    print(f\"📊 Dimensione: {file_size:.2f} MB\")\n",
    "    \n",
    "    return output_file\n",
    "\n",
    "# Crea video finale\n",
    "final_video = create_final_video(\n",
    "    ken_burns_videos,\n",
    "    MUSIC_FILE,\n",
    "    f\"{WORK_DIR}/final/quiet_cinema_final.mp4\"\n",
    ")\n",
    "\n",
    "print(f\"\\n✅ Pipeline completata!\")\n",
    "print(f\"📁 File finale: {final_video}\")"
   ]
