    "# @title Step 5: Assembla Video Finale con FFmpeg\n",
    "\n",
    "import os\n",
    "import subprocess\n",
    "\n",
    "# Assicurati che FFmpeg sia installato\n",
    "!which ffmpeg || apt-get update && apt-get install -y ffmpeg\n",
    "\n",
    "def create_slideshow_video(image_dir, output_file, duration_per_image=5):\n",
    "    \"\"\"Crea slideshow video da immagini\"\"\"\n",
    "    \n",
    "    images = sorted([f for f in os.listdir(image_dir) if f.endswith(('.png', '.jpg'))])\n",
    "    \n",
    "    if not images:\n",
    "        print(\"❌ Nessuna immagine trovata!\")\n",
    "        return None\n",
    "    \n",
    "    # Crea file concat per FFmpeg\n",
    "    concat_file = f\"{WORK_DIR}/video/concat_list.txt\"\n",
    "    with open(concat_file, 'w') as f:\n",
    "        for img in images:\n",
    "            f.write(f\"file '{image_dir}/{img}'\\n\")\n",
    "            f.write(f\"duration {duration_per_image}\\n\")\n",
    "        # Ultima immagine ripetuta\n",
    "        f.write(f\"file '{image_dir}/{images[-1]}'\\n\")\n",
    "    \n",
    "    # Crea slideshow\n",
    "    cmd = f\"\"\"\n",
    "    ffmpeg -y -f concat -safe 0 -i {concat_file} \n",
    "    -vf \"scale=1920:1080:force_original_aspect_ratio=decrease,pad=1920:1080:(ow-iw)/2:(oh-ih)/2,setsar=1,fps=30\"\n",
    "    -c:v libx264 -preset medium -crf 23 -pix_fmt yuv420p\n",
    "    {output_file}\n",
    "    \"\"\"\n",
    "    \n",
    "    subprocess.run(cmd, shell=True, check=True)\n",
    "    print(f\"✅ Slideshow video creato: {output_file}\")\n",
    "    return output_file\n",
    "\n",
    "# Crea video dalle immagini\n",
    "slideshow_video = create_slideshow_video(\n",
    "    f\"{WORK_DIR}/images\",\n",
    "    f\"{WORK_DIR}/final/slideshow_video.mp4\",\n",
    "    duration_per_image=5\n",
    ")\n",
    "\n",
    "print(f\"📹 Video slides: {slideshow_video}\")"
   ]
